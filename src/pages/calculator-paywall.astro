---
import Layout from "@/layouts/main.astro"
---

<Layout>
  <main class="mx-auto max-w-2xl p-6">
    <header class="mb-6">
      <a href="/" class="text-xs text-muted-foreground hover:text-foreground">
        ← 목록으로
      </a>
    </header>

    <div class="overflow-hidden rounded-xl ring-1 ring-foreground/10">
      <iframe
        src="/calculator/index.html"
        title="구독 계산기"
        class="block h-[760px] w-full border-0 bg-black"
        loading="lazy"
        sandbox="allow-scripts allow-same-origin allow-forms"
      ></iframe>
    </div>
  </main>
</Layout>
